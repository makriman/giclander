---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { promises as fs } from 'node:fs';
import path from 'node:path';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en')).sort((a, b) =>
  b.data.publishDate.localeCompare(a.data.publishDate),
);

const TRANSLATION_ROOT = path.join(process.cwd(), 'content-automation', 'generated-translations');

async function countTranslationFiles(root: string) {
  let total = 0;
  let dirs: fs.Dirent[] = [];

  try {
    dirs = await fs.readdir(root, { withFileTypes: true });
  } catch {
    return 0;
  }

  for (const dir of dirs) {
    if (!dir.isDirectory()) {
      continue;
    }

    const dirPath = path.join(root, dir.name);
    let names: string[] = [];
    try {
      names = await fs.readdir(dirPath);
    } catch {
      continue;
    }

    total += names.filter((name) => name.endsWith('.md')).length;
  }

  return total;
}

const translationCount = await countTranslationFiles(TRANSLATION_ROOT);
---

<BlogLayout
  title="Great Indian Company Blog"
  description="Research summaries and explainers based on Indian policy and economic sources."
  canonical="https://greatindiancompany.com/blog"
>
  <section class="card">
    <h1>Insights</h1>
    <p class="meta">{posts.length} published English articles</p>
    <p class="meta">{translationCount} published translation articles across 22 languages</p>
    <p class="meta">
      Sitemap: <a href="/sitemap-index.xml">/sitemap-index.xml</a>
    </p>

    <ul style="list-style:none; padding:0; margin:1rem 0 0; display:grid; gap:0.9rem;">
      {
        posts.map((post) => (
          <li style="border:1px solid #2d2d2d; border-radius:12px; padding:1rem; background:#111;">
            <a href={`/blog/${post.data.slug}`} style="font-size:1.03rem; font-weight:600;">
              {post.data.title}
            </a>
            <p style="margin:0.45rem 0 0; color:#bdbdbd;">{post.data.description}</p>
          </li>
        ))
      }
    </ul>
  </section>
</BlogLayout>
