---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { promises as fs } from 'node:fs';
import path from 'node:path';

function parseFrontmatter(raw: string) {
  const match = raw.match(/^---\n([\s\S]*?)\n---\n?/);
  if (!match) {
    return { frontmatter: '', body: raw };
  }

  return {
    frontmatter: match[1],
    body: raw.slice(match[0].length),
  };
}

function pickField(frontmatter: string, key: string) {
  const escaped = key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const match = frontmatter.match(new RegExp(`^${escaped}:\\s*(.*)$`, 'm'));
  if (!match) {
    return null;
  }

  return match[1].replace(/^"|"$/g, '').trim();
}

function pickArray(frontmatter: string, key: string) {
  const lines = frontmatter.split('\n');
  const values: string[] = [];
  let inBlock = false;

  for (const line of lines) {
    if (!inBlock) {
      if (line.startsWith(`${key}:`)) {
        inBlock = true;
      }
      continue;
    }

    if (line.startsWith('  - ')) {
      values.push(line.slice(4).trim().replace(/^"|"$/g, ''));
      continue;
    }

    if (line.trim() === '') {
      continue;
    }

    if (!line.startsWith(' ')) {
      break;
    }
  }

  return values;
}

function slugFromFile(filePath: string) {
  const base = path.basename(filePath).replace(/\.md$/, '');
  return base.replace(/^\d{4}-\d{2}-\d{2}-/, '');
}

function escapeHtml(value: string) {
  return value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderInline(text: string) {
  const escaped = escapeHtml(text);
  const withBold = escaped.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  return withBold.replace(
    /(https?:\/\/[^\s<]+)/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>',
  );
}

function renderSimpleMarkdown(markdown: string) {
  const lines = markdown.replace(/\r/g, '').split('\n');
  const html: string[] = [];
  let listBuffer: string[] = [];

  const flushList = () => {
    if (listBuffer.length === 0) {
      return;
    }
    html.push(`<ul>${listBuffer.join('')}</ul>`);
    listBuffer = [];
  };

  for (const line of lines) {
    const trimmed = line.trim();
    if (trimmed === '') {
      flushList();
      continue;
    }

    const h1 = trimmed.match(/^#\s+(.*)$/);
    if (h1) {
      flushList();
      html.push(`<h1>${renderInline(h1[1])}</h1>`);
      continue;
    }

    const h2 = trimmed.match(/^##\s+(.*)$/);
    if (h2) {
      flushList();
      html.push(`<h2>${renderInline(h2[1])}</h2>`);
      continue;
    }

    const h3 = trimmed.match(/^###\s+(.*)$/);
    if (h3) {
      flushList();
      html.push(`<h3>${renderInline(h3[1])}</h3>`);
      continue;
    }

    const li = trimmed.match(/^- (.*)$/);
    if (li) {
      listBuffer.push(`<li>${renderInline(li[1])}</li>`);
      continue;
    }

    flushList();
    html.push(`<p>${renderInline(trimmed)}</p>`);
  }

  flushList();
  return html.join('\n');
}

export async function getStaticPaths() {
  const translationRoot = path.join(process.cwd(), 'content-automation', 'generated-translations');
  const slugFromTranslationFile = (filePath: string) => {
    const base = path.basename(filePath).replace(/\.md$/, '');
    return base.replace(/^\d{4}-\d{2}-\d{2}-/, '');
  };
  const listTranslationFilesForBuild = async () => {
    const paths: string[] = [];
    let languages: fs.Dirent[] = [];
    try {
      languages = await fs.readdir(translationRoot, { withFileTypes: true });
    } catch {
      return paths;
    }

    for (const languageDir of languages) {
      if (!languageDir.isDirectory()) {
        continue;
      }

      const dirPath = path.join(translationRoot, languageDir.name);
      let names: string[] = [];
      try {
        names = await fs.readdir(dirPath);
      } catch {
        continue;
      }

      for (const name of names) {
        if (!name.endsWith('.md')) {
          continue;
        }
        paths.push(path.join(dirPath, name));
      }
    }

    return paths;
  };

  const masters = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');
  const translationFiles = await listTranslationFilesForBuild();

  const masterPaths = masters.map((post) => ({
    params: { slug: post.data.slug },
    props: { kind: 'master', post },
  }));

  const translationPaths = translationFiles.map((filePath) => ({
    params: { slug: slugFromTranslationFile(filePath) },
    props: { kind: 'translation', filePath },
  }));

  return [...masterPaths, ...translationPaths];
}

const props = Astro.props as { kind: 'master'; post: any } | { kind: 'translation'; filePath: string };

let title = '';
let description = '';
let slug = '';
let publishDate = '';
let lang = 'en';
let translationOf: string | null = null;
let tags: string[] = [];
let sourceLinks: string[] = [];
let translationHtml = '';
let masterContent: any = null;

if (props.kind === 'master') {
  const { post } = props;
  const rendered = await post.render();

  title = post.data.title;
  description = post.data.description;
  slug = post.data.slug;
  publishDate = post.data.publishDate;
  lang = post.data.lang;
  translationOf = post.data.translationOf;
  tags = post.data.tags;
  sourceLinks = post.data.sourceLinks;
  masterContent = rendered.Content;
} else {
  const raw = await fs.readFile(props.filePath, 'utf8');
  const { frontmatter, body } = parseFrontmatter(raw);

  title = pickField(frontmatter, 'title') || slugFromFile(props.filePath);
  description = pickField(frontmatter, 'description') || '';
  slug = pickField(frontmatter, 'slug') || slugFromFile(props.filePath);
  publishDate = pickField(frontmatter, 'publishDate') || '';
  lang = pickField(frontmatter, 'lang') || 'unknown';
  translationOf = pickField(frontmatter, 'translationOf');
  tags = pickArray(frontmatter, 'tags');
  sourceLinks = pickArray(frontmatter, 'sourceLinks');
  translationHtml = renderSimpleMarkdown(body);
}

const canonical = `https://greatindiancompany.com/blog/${slug}`;
const isTranslation = lang !== 'en';
const MasterContent = masterContent;
---

<BlogLayout title={title} description={description} canonical={canonical}>
  <article class="card">
    <h1>{title}</h1>
    <p class="meta">
      Published: {publishDate} | Language: {lang}{isTranslation
        ? ` | Master: ${translationOf}`
        : ''}
    </p>

    <div class="tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    {
      MasterContent ? (
        <div class="post-body">
          <MasterContent />
        </div>
      ) : (
        <div class="post-body" set:html={translationHtml}></div>
      )
    }

    <hr style="border:0; border-top:1px solid #2d2d2d; margin:1.75rem 0;" />

    <h2 style="margin:0 0 0.6rem; font-size:1.1rem;">Primary Sources</h2>
    <ul style="margin:0; padding-left:1.2rem;">
      {
        sourceLinks.map((url) => (
          <li>
            <a href={url} target="_blank" rel="noopener noreferrer">
              {url}
            </a>
          </li>
        ))
      }
    </ul>
  </article>
</BlogLayout>
