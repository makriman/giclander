---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en');

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const canonical = `https://greatindiancompany.com/blog/${post.data.slug}`;
const isTranslation = post.data.lang !== 'en';
---

<BlogLayout title={post.data.title} description={post.data.description} canonical={canonical}>
  <article class="card">
    <h1>{post.data.title}</h1>
    <p class="meta">
      Published: {post.data.publishDate} | Language: {post.data.lang}{isTranslation
        ? ` | Master: ${post.data.translationOf}`
        : ''}
    </p>

    <div class="tags">
      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>

    <div class="post-body">
      <Content />
    </div>

    <hr style="border:0; border-top:1px solid #2d2d2d; margin:1.75rem 0;" />

    <h2 style="margin:0 0 0.6rem; font-size:1.1rem;">Primary Sources</h2>
    <ul style="margin:0; padding-left:1.2rem;">
      {
        post.data.sourceLinks.map((url) => (
          <li>
            <a href={url} target="_blank" rel="noopener noreferrer">
              {url}
            </a>
          </li>
        ))
      }
    </ul>
  </article>
</BlogLayout>
